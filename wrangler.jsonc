{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "signalflare-incident-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-20",
  "workers_dev": true,
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
