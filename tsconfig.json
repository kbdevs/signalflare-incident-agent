{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": { "@/*": ["./web/*"] },
    "lib": ["ES2022", "DOM", "WebWorker"],
    "types": ["@cloudflare/workers-types", "vitest/globals", "node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "web/**/*.ts", "web/**/*.tsx", "vite.config.ts", "vitest.config.ts"]
}
