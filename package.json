    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@tailwindcss/vite": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
